@{
    ViewData["Title"] = "Access Denied";
}

<div class="row mt-5">
    <div class="col-md-6 offset-md-3 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
                <h2 class="mt-3">Access Denied</h2>
                <p class="lead text-muted">You don't have permission to access this resource.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                    <i class="bi bi-house"></i> Go to Home
                </a>
            </div>
        </div>
    </div>
</div>
