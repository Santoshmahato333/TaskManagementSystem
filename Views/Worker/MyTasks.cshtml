@using TaskStatus = TaskManagementSystem.Models.TaskStatus
@model List<TaskItem>
@{
    ViewData["Title"] = "My Tasks";
    var filter = ViewBag.Filter as TaskFilterViewModel;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-list-check"></i> My Tasks</h1>
    <a asp-action="CreateTask" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create Task
    </a>
</div>

<div class="card shadow mb-3">
    <div class="card-header bg-info text-white">
        <h6 class="mb-0"><i class="bi bi-funnel"></i> Filter My Tasks</h6>
    </div>
    <div class="card-body">
        <form method="get" asp-action="MyTasks">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="SearchTerm" value="@filter?.SearchTerm" class="form-control" placeholder="Search by title or description..." />
                </div>
                <div class="col-md-3">
                    <select name="Status" class="form-select">
                        <option value="">All Status</option>
                        @foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status" selected="@(filter?.Status?.ToString() == status.ToString())">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="Priority" class="form-select">
                        <option value="">All Priority</option>
                        @foreach (var priority in ViewBag.Priorities)
                        {
                            <option value="@priority" selected="@(filter?.Priority?.ToString() == priority.ToString())">@priority</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Created By</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th>Created</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model)
                        {
                            <tr class="@(task.DueDate < DateTime.Now && task.Status != TaskStatus.Completed ? "table-danger" : "")">
                                <td>
                                    <strong>@task.Title</strong>
                                    @if (!string.IsNullOrEmpty(task.Description))
                                    {
                                        <br /><small class="text-muted">@task.Description.Substring(0, Math.Min(100, task.Description.Length))@(task.Description.Length > 100 ? "..." : "")</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(task.AttachmentPath))
                                    {
                                        <div class="mt-2">
                                            @await Html.PartialAsync("_TaskAttachment", task, new ViewDataDictionary(ViewData) { ["Compact"] = true })
                                        </div>
                                    }
                                </td>
                                <td>@task.CreatedByUser.FullName</td>
                                <td>
                                    @switch (task.Priority)
                                    {
                                        case TaskPriority.Low: <span class="badge bg-secondary">Low</span> break;
                                        case TaskPriority.Medium: <span class="badge bg-info">Medium</span> break;
                                        case TaskPriority.High: <span class="badge bg-warning">High</span> break;
                                        case TaskPriority.Critical: <span class="badge bg-danger">Critical</span> break;
                                    }
                                </td>
                                <td>
                                    @switch (task.Status)
                                    {
                                        case TaskStatus.Pending: <span class="badge bg-warning">Pending</span> break;
                                        case TaskStatus.InProgress: <span class="badge bg-info">In Progress</span> break;
                                        case TaskStatus.Completed: <span class="badge bg-success">Completed</span> break;
                                        case TaskStatus.Cancelled: <span class="badge bg-danger">Cancelled</span> break;
                                    }
                                </td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <span class="@(task.DueDate < DateTime.Now && task.Status != TaskStatus.Completed ? "text-danger fw-bold" : "")">
                                            @task.DueDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No deadline</span>
                                    }
                                </td>
                                <td>@task.CreatedDate.ToString("MMM dd")</td>
                                <td>
                                    <a asp-action="ViewTaskDetails" asp-route-id="@task.TaskId" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="MyTasks" asp-route-PageNumber="@i"
                                   asp-route-SearchTerm="@filter?.SearchTerm"
                                   asp-route-Status="@filter?.Status"
                                   asp-route-Priority="@filter?.Priority">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <i class="bi bi-list-check" style="font-size: 4rem;"></i>
        <h4>No tasks assigned yet</h4>
        <p class="mb-0">Your admin will assign tasks to you soon.</p>
    </div>
}
