@using TaskStatus = TaskManagementSystem.Models.TaskStatus
@using TaskPriority = TaskManagementSystem.Models.TaskPriority
@model List<TaskItem>
@{
    ViewData["Title"] = "All Tasks";
    var filter = ViewBag.Filter as TaskFilterViewModel;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-list-task"></i> All Tasks</h1>
    <a asp-action="CreateTask" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Task
    </a>
</div>

<div class="card shadow mb-3">
    <div class="card-header bg-light">
        <h6 class="mb-0"><i class="bi bi-funnel"></i> Filter Tasks</h6>
    </div>
    <div class="card-body">
        <form method="get" asp-action="TaskList">
            <div class="row g-2">
                <div class="col-md-3">
                    <input type="text" name="SearchTerm" value="@filter?.SearchTerm" class="form-control" placeholder="Search by title..." />
                </div>
                <div class="col-md-2">
                    <select name="Status" class="form-select">
                        <option value="">All Status</option>
                        @foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status" selected="@(filter?.Status?.ToString() == status.ToString())">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="Priority" class="form-select">
                        <option value="">All Priority</option>
                        @foreach (var priority in ViewBag.Priorities)
                        {
                            <option value="@priority" selected="@(filter?.Priority?.ToString() == priority.ToString())">@priority</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="AssignedToUserId" asp-items="ViewBag.Workers" class="form-select">
                        <option value="">All Workers</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Assigned To</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@task.Title</strong><br>
                                    <small class="text-muted">@(task.Description != null && task.Description.Length > 50 ? task.Description.Substring(0, 50) + "..." : task.Description)</small>
                                </td>
                                <td>@task.AssignedToUser.FullName</td>
                                <td>
                                    @switch (task.Priority)
                                    {
                                        case TaskPriority.Low:
                                            <span class="badge bg-secondary">Low</span>
                                            break;
                                        case TaskPriority.Medium:
                                            <span class="badge bg-info">Medium</span>
                                            break;
                                        case TaskPriority.High:
                                            <span class="badge bg-warning">High</span>
                                            break;
                                        case TaskPriority.Critical:
                                            <span class="badge bg-danger">Critical</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @switch (task.Status)
                                    {
                                        case TaskStatus.Pending:
                                            <span class="badge bg-warning">Pending</span>
                                            break;
                                        case TaskStatus.InProgress:
                                            <span class="badge bg-info">In Progress</span>
                                            break;
                                        case TaskStatus.Completed:
                                            <span class="badge bg-success">Completed</span>
                                            break;
                                        case TaskStatus.Cancelled:
                                            <span class="badge bg-danger">Cancelled</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <span class="@(task.DueDate < DateTime.Now && task.Status != TaskStatus.Completed ? "text-danger" : "")">
                                            @task.DueDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>@task.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="ViewTaskDetails" asp-route-id="@task.TaskId" class="btn btn-outline-primary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="EditTask" asp-route-id="@task.TaskId" class="btn btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-action="DeleteTask" asp-route-id="@task.TaskId" style="display:inline;" 
                                              onsubmit="return confirm('Are you sure you want to delete this task?');">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="TaskList" asp-route-PageNumber="@i" 
                                   asp-route-SearchTerm="@filter?.SearchTerm"
                                   asp-route-Status="@((int?)filter?.Status)"
                                   asp-route-Priority="@((int?)filter?.Priority)">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No tasks found. 
        <a asp-action="CreateTask" class="alert-link">Create a new task</a>
    </div>
}
