@model DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-speedometer2"></i> Dashboard</h1>
    <div class="text-muted">
        <span>Welcome, <strong>@Model.UserFullName</strong></span> | 
        <span><i class="bi bi-building"></i> @Model.DepartmentName Department</span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-subtitle mb-2">Total Tasks</h6>
                        <h2 class="mb-0">@Model.TotalTasks</h2>
                    </div>
                    <div>
                        <i class="bi bi-list-task" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-subtitle mb-2">Pending</h6>
                        <h2 class="mb-0">@Model.PendingTasks</h2>
                    </div>
                    <div>
                        <i class="bi bi-clock" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-info shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-subtitle mb-2">In Progress</h6>
                        <h2 class="mb-0">@Model.InProgressTasks</h2>
                    </div>
                    <div>
                        <i class="bi bi-arrow-repeat" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-subtitle mb-2">Completed</h6>
                        <h2 class="mb-0">@Model.CompletedTasks</h2>
                    </div>
                    <div>
                        <i class="bi bi-check-circle" style="font-size: 3rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-people-fill text-primary"></i> Active Workers</h5>
                <h2 class="display-4">@Model.ActiveWorkers</h2>
                <a asp-action="ManageWorkers" class="btn btn-sm btn-outline-primary mt-2">
                    <i class="bi bi-arrow-right"></i> View All
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-exclamation-triangle text-danger"></i> Critical Tasks</h5>
                <h2 class="display-4 text-danger">@Model.CriticalTasks</h2>
                <a asp-action="TaskList" asp-route-Priority="Critical" class="btn btn-sm btn-outline-danger mt-2">
                    <i class="bi bi-arrow-right"></i> View Tasks
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-calendar-x text-warning"></i> Overdue Tasks</h5>
                <h2 class="display-4 text-warning">@Model.OverdueTasks</h2>
                <a asp-action="TaskList" class="btn btn-sm btn-outline-warning mt-2">
                    <i class="bi bi-arrow-right"></i> View Tasks
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-graph-up"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-3">
                        <a asp-action="CreateTask" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-plus-circle"></i><br>Create Task
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a asp-action="TaskList" class="btn btn-outline-primary btn-lg w-100">
                            <i class="bi bi-list-task"></i><br>View All Tasks
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-success btn-lg w-100">
                            <i class="bi bi-person-plus"></i><br>Add Worker
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a asp-action="Reports" class="btn btn-outline-info btn-lg w-100">
                            <i class="bi bi-file-earmark-bar-graph"></i><br>View Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
