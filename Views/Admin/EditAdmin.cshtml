@model User
@{
    ViewData["Title"] = "Edit Admin Account";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-pencil-square"></i> Edit Admin Account</h1>
    <a asp-action="ManageAdmins" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Admins
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle"></i> Please correct the errors below.
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label for="FullName" class="form-label">Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="FullName" name="FullName" value="@Model.FullName" required>
                    </div>

                    <div class="mb-3">
                        <label for="Username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="Username" name="Username" value="@Model.Username" disabled>
                        <small class="form-text text-muted">Username cannot be changed</small>
                    </div>

                    <div class="mb-3">
                        <label for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="Email" name="Email" value="@Model.Email" required>
                    </div>

                    <div class="mb-3">
                        <label for="PhoneNumber" class="form-label">Phone Number</label>
                        <input type="tel" class="form-control" id="PhoneNumber" name="PhoneNumber" value="@(Model.PhoneNumber ?? "")">
                    </div>

                    <div class="mb-3">
                        <label for="IsActive" class="form-label">Account Status</label>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" 
                                   @(Model.IsActive ? "checked" : "")>
                            <label class="form-check-label" for="IsActive">
                                Active Account
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Roles</label>
                        <div class="border rounded p-3">
                            @foreach (var role in Model.UserRoles)
                            {
                                <div class="alert alert-info mb-2">
                                    <strong>@role.Role.RoleName</strong> in <strong>@role.Department.DepartmentName</strong>
                                    <br>
                                    <small class="text-muted">Assigned on @role.AssignedDate.ToString("MMM dd, yyyy")</small>
                                </div>
                            }
                        </div>
                        <small class="form-text text-muted">To change roles, delete this admin and create a new one with the desired role.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Account Information</label>
                        <div class="alert alert-secondary">
                            <small>
                                <strong>Created:</strong> @Model.CreatedDate.ToString("MMM dd, yyyy HH:mm:ss")<br>
                                <strong>User ID:</strong> @Model.UserId
                            </small>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="ManageAdmins" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-light">
                <h6 class="mb-0">Admin Information</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Username:</strong>
                    <p class="mb-2">@Model.Username</p>
                </div>
                <div class="mb-3">
                    <strong>Status:</strong>
                    <p class="mb-2">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </p>
                </div>
                <div class="mb-3">
                    <strong>Created:</strong>
                    <p class="mb-2">@Model.CreatedDate.ToString("MMM dd, yyyy")</p>
                </div>
                <div class="mb-3">
                    <strong>Assigned Tasks:</strong>
                    <p class="mb-0">@Model.CreatedTasks.Count</p>
                </div>
            </div>
        </div>
    </div>
</div>
