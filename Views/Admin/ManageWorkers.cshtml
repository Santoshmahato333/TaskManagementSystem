@model List<User>
@{
    ViewData["Title"] = "Manage Workers";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-people"></i> Manage Workers</h1>
    <a asp-controller="Account" asp-action="Register" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add New Worker
    </a>
</div>

@if (Model.Any())
{
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Username</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var worker in Model)
                        {
                            <tr>
                                <td><strong>@worker.Username</strong></td>
                                <td>@worker.FullName</td>
                                <td><i class="bi bi-envelope"></i> @worker.Email</td>
                                <td><i class="bi bi-phone"></i> @(worker.PhoneNumber ?? "N/A")</td>
                                <td>
                                    @if (worker.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>@worker.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a asp-action="TaskList" asp-route-AssignedToUserId="@worker.UserId" 
                                       class="btn btn-sm btn-outline-primary" title="View Tasks">
                                        <i class="bi bi-list-task"></i> Tasks
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No workers found in your department. 
        <a asp-controller="Account" asp-action="Register" class="alert-link">Add a new worker</a>
    </div>
}
